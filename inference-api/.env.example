# GPU Worker SSH access (for remote worker management)
RUNPOD_SSH_HOST=your-gpu-host.example.com
RUNPOD_SSH_PORT=22
RUNPOD_SSH_USER=root

# GPU Worker gRPC endpoints (via SSH tunnel or direct)
GPU_WORKER_0_URL=localhost:50051
GPU_WORKER_1_URL=localhost:50052
GPU_TP_WORKER_URL=localhost:50051

# Worker mode: 'individual' (2 separate workers) or 'tensor-parallel' (1 TP worker)
WORKER_MODE=individual

# Remote paths
GPU_WORKER_PATH=/workspace/gpu-worker
HF_HOME=/workspace/huggingface_cache

# ClickHouse (optional — metrics degrade gracefully if unavailable)
CLICKHOUSE_URL=http://localhost:8123

# API server
PORT=3000
